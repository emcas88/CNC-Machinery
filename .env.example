# =============================================================================
# CNC Machinery — Environment Variables
# F21: Backend Compilation Fixes
#
# Copy this file to .env and fill in production values.
# =============================================================================

# ── Core ───────────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://cnc_user:cnc_password@db:5432/cnc_machinery

# Logging level (error, warn, info, debug, trace)
RUST_LOG=info,actix_web=debug

# Server bind address & port
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ── Redis ──────────────────────────────────────────────────────────────────────
# Used for session cache and pub/sub
REDIS_URL=redis://redis:6379

# ── MinIO / S3 ─────────────────────────────────────────────────────────────────
# S3-compatible object storage for G-code files, exports, labels
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=cnc_minio
MINIO_SECRET_KEY=cnc_minio_secret
MINIO_BUCKET=cnc-files
# Docker-compose also needs these for the minio service itself:
MINIO_ROOT_USER=cnc_minio
MINIO_ROOT_PASSWORD=cnc_minio_secret

# ── JWT Authentication ────────────────────────────────────────────────────────
# Secret key for signing JWTs (required — use a long random string)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Access token lifetime in seconds (default: 900 = 15 minutes)
JWT_ACCESS_EXPIRES_SECS=900

# Refresh token lifetime in seconds (default: 604800 = 7 days)
JWT_REFRESH_EXPIRES_SECS=604800

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
