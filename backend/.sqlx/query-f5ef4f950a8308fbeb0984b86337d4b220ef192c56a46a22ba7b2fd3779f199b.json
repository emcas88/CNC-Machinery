{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT pp.id AS placement_id,\n               pp.part_id,\n               pp.x, pp.y,\n               pp.rotated,\n               p.name,\n               p.length,\n               p.width\n          FROM part_placements pp\n          JOIN parts p ON p.id = pp.part_id\n         WHERE pp.sheet_id = $1\n         ORDER BY pp.y, pp.x\n        ",
