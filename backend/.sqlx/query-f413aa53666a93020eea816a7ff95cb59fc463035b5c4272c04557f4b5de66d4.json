  "query": "\n        INSERT INTO hardware (\n            id, name, sku, hardware_type,\n            supplier, unit_cost, description,\n            created_at, updated_at\n        )\n        VALUES (\n            gen_random_uuid(), $1, $2, $3,\n            $4, $5, $6,\n            NOW(), NOW()\n        )\n        RETURNING\n            id, name, sku, hardware_type,\n            supplier, unit_cost, description,\n            created_at, updated_at\n        ",
