{
  "db_name": "PostgreSQL",
  "query": "\n        UPDATE quotes SET\n            job_id            = COALESCE($2, job_id),\n            quote_number      = COALESCE($3, quote_number),\n            material_cost     = $4,\n            hardware_cost     = $5,\n            labor_cost        = $6,\n            markup_percentage = $7,\n            total             = $8,\n            line_items        = COALESCE($9, line_items),\n            updated_at        = $10\n        WHERE id = $1\n        RETURNING\n            id,\n            job_id,\n            quote_number,\n            material_cost,\n            hardware_cost,\n            labor_cost,\n            markup_percentage,\n            total,\n            line_items,\n            created_at,\n            updated_at\n        ",
