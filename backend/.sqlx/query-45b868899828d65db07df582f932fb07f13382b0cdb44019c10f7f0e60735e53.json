  "query": "\n        INSERT INTO rooms (\n            id, job_id, name, width, height, depth, notes,\n            material_overrides, construction_overrides,\n            created_at, updated_at\n        )\n        VALUES (\n            gen_random_uuid(), $1, $2, $3, $4, $5, $6,\n            $7, $8,\n            NOW(), NOW()\n        )\n        RETURNING id, job_id, name, width, height, depth, notes,\n                  material_overrides, construction_overrides,\n                  created_at, updated_at\n        ",
