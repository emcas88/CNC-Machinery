  "query": "\n        INSERT INTO materials (\n            id, name, sku, material_type,\n            thickness_mm, width_mm, length_mm,\n            supplier, cost_per_sheet, description,\n            created_at, updated_at\n        )\n        VALUES (\n            gen_random_uuid(), $1, $2, $3,\n            $4, $5, $6,\n            $7, $8, $9,\n            NOW(), NOW()\n        )\n        RETURNING\n            id, name, sku, material_type,\n            thickness_mm, width_mm, length_mm,\n            supplier, cost_per_sheet, description,\n            created_at, updated_at\n        ",
