{
  "db_name": "PostgreSQL",
  "query": "\n        UPDATE users SET\n            email       = COALESCE($2, email),\n            name        = COALESCE($3, name),\n            role        = COALESCE($4::text::user_role, role),\n            permissions = COALESCE($5, permissions),\n            updated_at  = $6\n        WHERE id = $1\n        RETURNING\n            id,\n            email,\n            name,\n            role AS \"role: UserRole\",\n            permissions,\n            created_at,\n            updated_at\n        ",
